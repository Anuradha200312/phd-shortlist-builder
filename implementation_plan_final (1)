);

CREATE INDEX idx_cache_expires ON api_cache (expires_at);
-- Auto-cleanup: remove expired cache entries
CREATE OR REPLACE FUNCTION purge_expired_cache() RETURNS void AS $$
    DELETE FROM api_cache WHERE expires_at < NOW();
$$ LANGUAGE SQL;
