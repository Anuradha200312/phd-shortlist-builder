);

CREATE INDEX idx_papers_supervisor  ON papers (supervisor_id);
CREATE INDEX idx_papers_year        ON papers (year DESC);
CREATE INDEX idx_papers_fts         ON papers USING GIN (search_vector);  -- full-text search

-- ─────────────────────────────────────────────
-- Grants linked to supervisors
-- ─────────────────────────────────────────────
CREATE TABLE grants (
    id              TEXT PRIMARY KEY,
    supervisor_id   TEXT REFERENCES supervisors(id) ON DELETE CASCADE,
    title           TEXT NOT NULL,
    funder          TEXT,
    amount_usd      INTEGER,
    start_year      INTEGER,
    end_year        INTEGER,
    url             TEXT,
    abstract        TEXT,
