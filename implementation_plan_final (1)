    raw_api_payload:  Mapped[dict | None]   = mapped_column(JSONB)
    fetched_at:       Mapped[datetime]      = mapped_column(TIMESTAMPTZ)
    
    papers:           Mapped[list["Paper"]] = relationship(back_populates="supervisor", cascade="all, delete")
    grants:           Mapped[list["Grant"]] = relationship(back_populates="supervisor", cascade="all, delete")

class Shortlist(Base):
    __tablename__ = "shortlists"
    
    id:                  Mapped[uuid.UUID]  = mapped_column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    student_id:          Mapped[str]        = mapped_column(String, nullable=False)
