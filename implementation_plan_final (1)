### 14.2 LangGraph Pipeline Graph Definition

```python
# graph/pipeline_graph.py
from langgraph.graph import StateGraph, END
from langgraph.checkpoint.sqlite import SqliteSaver
from graph.state import ShortlistState
from graph.nodes import (
    ingest_node, retrieve_node, resolve_node, verify_pi_node,
    score_node, enrich_node, validate_node, output_node
)
from graph.edges import should_retry_retrieval

def build_pipeline_graph(settings) -> StateGraph:
    builder = StateGraph(ShortlistState)
    
    # Register all nodes
    builder.add_node("ingest_node", ingest_node)
    builder.add_node("retrieve_node", retrieve_node)
    builder.add_node("resolve_node", resolve_node)
    builder.add_node("verify_pi_node", verify_pi_node)
    builder.add_node("score_node", score_node)
    builder.add_node("enrich_node", enrich_node)
    builder.add_node("validate_node", validate_node)
    builder.add_node("output_node", output_node)
    
    # Linear edges
    builder.set_entry_point("ingest_node")
    builder.add_edge("ingest_node", "retrieve_node")
    builder.add_edge("retrieve_node", "resolve_node")
    builder.add_edge("resolve_node", "verify_pi_node")
    
    # Conditional edge: retry retrieval if < 50 candidates
    builder.add_conditional_edges(
        "verify_pi_node",
        should_retry_retrieval,
        {
            "retrieve_node": "retrieve_node",   # loop back
            "score_node": "score_node",          # proceed
        }
    )
    
    builder.add_edge("score_node", "enrich_node")
    builder.add_edge("enrich_node", "validate_node")
    builder.add_edge("validate_node", "output_node")
    builder.add_edge("output_node", END)
    
    # Compile with persistent checkpointing
    checkpointer = SqliteSaver.from_conn_string("data/checkpoints.db")
    return builder.compile(checkpointer=checkpointer)
```

### 14.3 Conditional Edge — Retry if Insufficient Candidates

```python
# graph/edges.py

MAX_RETRIEVAL_ATTEMPTS = 3
MIN_CANDIDATES_REQUIRED = 50

def should_retry_retrieval(state: ShortlistState) -> str:
    """Route to retrieve_node for more candidates, or proceed to score_node."""
    candidate_count = len(state["resolved_candidates"])
    attempts = state["retrieval_attempts"]
    
    if candidate_count < MIN_CANDIDATES_REQUIRED and attempts < MAX_RETRIEVAL_ATTEMPTS:
