# Grounding check for why_match (runs inside validate_node)
def validate_why_match(why_match: str, supervisor: dict, student: dict) -> bool:
    evidence_titles = [e["title"].lower() for e in supervisor["evidence"]]
    text_lower = why_match.lower()
    
    references_real_work = any(title[:20] in text_lower for title in evidence_titles)
    references_student_area = any(
        interest.lower() in text_lower for interest in student["research_interests"]
    )
    is_not_generic = not any(
        phrase in text_lower for phrase in [
            "your research background", "your impressive work", "your academic journey"
        ]
    )
    return references_real_work and references_student_area and is_not_generic
