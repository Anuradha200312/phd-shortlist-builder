            f"Only {candidate_count} candidates after resolve — retrying retrieval "
            f"(attempt {attempts + 1}/{MAX_RETRIEVAL_ATTEMPTS})"
        )
        return "retrieve_node"
    
    logger.info(f"Proceeding with {candidate_count} candidates to score_node")
    return "score_node"
