### 15.3 Improvement 3 — Faculty Directory Hard Gate (Challenge: Career-Stage Errors)

**Problem**: PhD students and postdocs appear in academic databases just like professors.

**Solution**: Confirm PI status via university faculty directory (institution-verified) AND check for publication staleness.

```python
# tools/faculty_directory_tool.py
from langchain_core.tools import tool
import httpx
from bs4 import BeautifulSoup

# Common university faculty directory URL patterns
FACULTY_DIR_PATTERNS = [
    "https://{domain}/faculty",
    "https://{domain}/people/faculty",
    "https://{domain}/department/faculty-staff",
    "https://directory.{domain}/faculty",
]

@tool
async def check_faculty_directory(name: str, institution: str) -> dict:
    """
    Verify that a researcher is listed as faculty on their institution's website.
    Returns: {confirmed: bool, profile_url: str | None, title_found: str | None}
    
    This is the hardest-to-fake signal — university HR maintains these lists.
    """
    domain = resolve_institution_domain(institution)  # "MIT" → "mit.edu"
    
    for pattern in FACULTY_DIR_PATTERNS:
        url = pattern.format(domain=domain)
        try:
            async with httpx.AsyncClient(timeout=8) as client:
                resp = await client.get(url, follow_redirects=True)
                if resp.status_code == 200:
                    soup = BeautifulSoup(resp.text, "html.parser")
                    text = soup.get_text().lower()
                    name_lower = name.lower()
                    
                    if name_lower in text:
                        # Find the surrounding context to extract title
                        idx = text.find(name_lower)
                        context = text[max(0, idx-100):idx+200]
                        title = extract_position_title(context)
                        
                        return {
                            "confirmed": True,
                            "profile_url": url,
                            "title_found": title,
                            "source": "faculty_directory"
                        }
        except Exception:
            continue
    
    return {"confirmed": False, "profile_url": None, "title_found": None, "source": "not_found"}


# graph/nodes/verify_pi_node.py — enhanced with faculty gate + staleness

CURRENT_YEAR = datetime.now().year
STALENESS_THRESHOLD_YEARS = 4    # no papers in 4+ years = likely inactive

async def verify_pi_node(state: ShortlistState) -> ShortlistState:
    verified = []
    
    for candidate in state["resolved_candidates"]:
        
        # Gate 1: Rule-based pre-filter (fastest — free)
        if not rule_based_pi_check(candidate):
            log_contamination(candidate, "verify_pi_node", "rule_based_reject", "removed", state)
            continue
        
        # Gate 2: Staleness check (fast — no API call)
        last_paper = candidate.get("last_paper_year", 0)
        if last_paper and (CURRENT_YEAR - last_paper) > STALENESS_THRESHOLD_YEARS:
            candidate["tier"] = "low_activity"   # don't remove, just deprioritize
            candidate["contamination_risk"] = candidate.get("contamination_risk", []) + ["stale_publication_record"]
            logger.info("Stale supervisor deprioritized", name=candidate["name"], last_paper=last_paper)
        
        # Gate 3: Faculty directory confirmation (medium — HTTP call, cached)
        dir_result = await check_faculty_directory(
            name=candidate["name"],
            institution=candidate["institution"]
        )
        candidate["faculty_page_confirmed"] = dir_result["confirmed"]
        
        if not dir_result["confirmed"]:
            # Not on faculty page — could be postdoc / visiting / industry
            # Don't auto-reject, but flag and send to LLM for final call
            candidate["contamination_risk"] = candidate.get("contamination_risk", []) + ["faculty_page_unconfirmed"]
        
        # Gate 4: LLM verification (slowest — only for borderline cases)
        if needs_llm_verification(candidate):
            result = await pi_verify_chain.ainvoke({
                "name": candidate["name"],
                "position_title": candidate.get("position_title", "unknown"),
