### 15.1 Improvement 1 — 3-Signal Lock (Challenge: Same-Name Collisions)

**Problem**: "Wei Wang" returns 1,000+ researchers. Name + institution alone is not enough.

**Solution**: A candidate only passes `resolve_node` if they satisfy **at least 2 of 3 independent signals**.

```python
# entity_resolution/name_disambiguator.py

from dataclasses import dataclass

@dataclass
class DisambiguationSignals:
    orcid_verified: bool         # Signal 1: ORCID matches expected research area
    faculty_page_confirmed: bool # Signal 2: Name found on university faculty directory
    embedding_match: bool        # Signal 3: Paper topics cosine similarity > 0.70
    signals_passed: int          # 0, 1, 2, or 3
    passes_lock: bool            # True if signals_passed >= 2

async def apply_three_signal_lock(
    candidate: dict,
    student_interests_embedding: list[float],
    min_signals: int = 2
) -> DisambiguationSignals:
    """
    3-Signal Lock: Require at least 2/3 independent identity verifications.
    
    This is far more robust than name-matching alone because:
    - ORCID is globally unique and researcher-claimed
    - Faculty directory is institution-verified
    - Embedding similarity is research-area-verified
    A collision must fool ALL 3 signals to get through — statistically near-impossible.
    """
    
    # Signal 1: ORCID verification
    orcid_ok = False
    if candidate.get("orcid"):
        orcid_data = await fetch_orcid_profile(candidate["orcid"])
        if orcid_data:
            orcid_areas = extract_orcid_keywords(orcid_data)
            orcid_ok = any_overlap(orcid_areas, student_interests)
    
    # Signal 2: Faculty directory confirmation
    faculty_ok = False
    if candidate.get("institution"):
        faculty_ok = await check_faculty_directory(
            name=candidate["name"],
            institution=candidate["institution"]
        )
    
    # Signal 3: Embedding similarity
    embed_ok = False
    if candidate.get("research_summary"):
        candidate_embedding = embedder.embed_query(candidate["research_summary"])
        similarity = cosine_similarity(student_interests_embedding, candidate_embedding)
        embed_ok = similarity > 0.70
    
    passed = sum([orcid_ok, faculty_ok, embed_ok])
    
    return DisambiguationSignals(
        orcid_verified=orcid_ok,
        faculty_page_confirmed=faculty_ok,
        embedding_match=embed_ok,
        signals_passed=passed,
        passes_lock=passed >= min_signals
    )

# In resolve_node — apply to every candidate:
async def resolve_node(state: ShortlistState) -> ShortlistState:
    student_embedding = embedder.embed_query(
        ", ".join(state["student_profile"]["research_interests"])
    )
    
    resolved = []
    disambiguation_results = {}
    
    for candidate in state["raw_candidates"]:
        signals = await apply_three_signal_lock(candidate, student_embedding)
        disambiguation_results[candidate["id"]] = {
            "orcid_verified": signals.orcid_verified,
            "faculty_page_confirmed": signals.faculty_page_confirmed,
            "embedding_match": signals.embedding_match,
            "signals_passed": signals.signals_passed,
        }
        
        if signals.passes_lock:
            candidate["disambiguation_signals"] = disambiguation_results[candidate["id"]]
            resolved.append(candidate)
        else:
            logger.info(
                "3-signal-lock rejected",
                name=candidate["name"],
                institution=candidate["institution"],
                signals_passed=signals.signals_passed
            )
    
    return {**state, "resolved_candidates": resolved, "disambiguation_results": disambiguation_results}
```

