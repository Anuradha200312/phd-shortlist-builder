            })
            if not result.is_faculty_pi:
                log_contamination(candidate, "verify_pi_node", "llm_not_pi", "removed", state)
                continue
            candidate["career_stage"] = result.career_stage
        
        verified.append(candidate)
    
    return {**state, "resolved_candidates": verified}

def needs_llm_verification(candidate: dict) -> bool:
    """Only send to LLM if rule-based checks are inconclusive."""
    # Definitely a PI (no LLM needed):
    if candidate.get("faculty_page_confirmed") and candidate.get("h_index", 0) > 15:
        return False
    # Definitely NOT a PI (already rejected — won't reach here):
    # Borderline — needs LLM:
    return True
