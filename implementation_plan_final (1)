    is_pi_verified      BOOLEAN DEFAULT NULL,    -- NULL=unchecked, TRUE/FALSE=verified
    career_stage        TEXT CHECK (career_stage IN ('faculty','postdoc','student','unknown')),
    research_areas      TEXT[],                  -- PostgreSQL native array
    raw_api_payload     JSONB,                   -- full API response for debugging
    chroma_doc_id       TEXT,                    -- LangChain Chroma document ID
    embedding           vector(384),             -- pgvector: all-MiniLM-L6-v2 dims (optional)
    fetched_at          TIMESTAMPTZ DEFAULT NOW(),
