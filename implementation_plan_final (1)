);

CREATE INDEX idx_outcomes_student    ON outcomes (student_id);
CREATE INDEX idx_outcomes_supervisor ON outcomes (supervisor_id);
CREATE INDEX idx_outcomes_outcome    ON outcomes (outcome);
CREATE INDEX idx_outcomes_sent_at    ON outcomes (sent_at DESC);

-- ─────────────────────────────────────────────
-- Supervisor performance signals (derived from outcomes)
-- ─────────────────────────────────────────────
CREATE TABLE supervisor_signals (
    supervisor_id       TEXT PRIMARY KEY REFERENCES supervisors(id),
    total_emails        INTEGER DEFAULT 0,
    positive_responses  INTEGER DEFAULT 0,       -- ADMIT + INTERVIEW + POSITIVE_REPLY
    admit_count         INTEGER DEFAULT 0,
    response_rate       NUMERIC(5,4),            -- 0.0000–1.0000
    area_success        JSONB DEFAULT '{}',      -- {"medical_imaging": 0.75, ...}
