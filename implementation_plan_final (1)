    if position.get("eligibility_structured"):
        result = extract_eligibility_structured(position)
        if result is not None:
            return result   # ← No LLM call needed!
    
    # Fallback: LLM on raw ad text
    ad_text = position.get("description", "")[:800]
    if not ad_text:
        return {"flags": ["unknown"], "method": "no_text", "llm_used": False}
    
    result = await eligibility_chain.ainvoke({"text": ad_text})
    return {**result.dict(), "method": "llm_fallback", "llm_used": True}
