);

-- ─────────────────────────────────────────────
-- API response cache (replaces diskcache for shared deployments)
-- ─────────────────────────────────────────────
CREATE TABLE api_cache (
    cache_key       TEXT PRIMARY KEY,
    source          TEXT,                        -- 'semantic_scholar' | 'openalex' | etc.
