### 15.2 Improvement 2 — Two-Layer Domain Check (Challenge: Wrong-Domain Leakage)

**Problem**: Naive keyword matching surfaces "biodegradable plastic cartridges" (military ammo) for a biomaterials student.

**Solution**: Fast keyword blacklist eliminates obvious mismatches before spending any LLM tokens.

```python
# entity_resolution/domain_classifier.py

import re

# Layer 1: Keyword Blacklist (instant, free, catches obvious mismatches)
DOMAIN_BLACKLISTS = {
    "military_defense": [
        r"\bballi?stic\b", r"\bmunition", r"\bwarfare\b", r"\bcombat\b",
        r"\barmament\b", r"\bdefense contractor\b", r"\bDARPA\b",
        r"\bweapon system\b", r"\bexplosive\b"
    ],
    "classical_humanities": [
        r"\bRoman antiquit", r"\bGreek literature\b", r"\bLatin philolog",
        r"\bmedieval manuscript\b", r"\bNorse saga\b", r"\bByzantine\b",
        r"\bclassical archaeology\b"
    ],
    "wrong_biomaterials": [
        r"\bplastic cartridge\b", r"\bbullet casing\b", r"\bammunition\b"
    ],
}

# Academic venue → discipline mapping (Layer 2 shortcut)
VENUE_DISCIPLINE_MAP = {
    # Computer Science / AI
    "NeurIPS": "ai_ml", "ICML": "ai_ml", "CVPR": "computer_vision",
    "ICLR": "ai_ml", "EMNLP": "nlp", "ACL": "nlp", "SIGKDD": "data_mining",
    # Medicine / Biology  
    "NEJM": "medicine", "JAMA": "medicine", "Lancet": "medicine",
    "Nature Medicine": "medicine", "Radiology": "medical_imaging",
    # Humanities (red flag for STEM students)
    "PMLA": "literary_studies", "ELH": "literary_studies",
    "Classical Quarterly": "classics", "Speculum": "medieval_studies",
}

def layer1_blacklist_check(title: str, abstract: str, student_domain: str) -> tuple[bool, str]:
    """
    Fast blacklist check. Returns (passes, reason).
    If fails, skip LLM entirely.
    """
    text = f"{title} {abstract}".lower()
    
    for category, patterns in DOMAIN_BLACKLISTS.items():
        for pattern in patterns:
            if re.search(pattern, text, re.IGNORECASE):
                return False, f"blacklist_match:{category}:{pattern}"
    
    return True, "passes_blacklist"

def layer1_venue_check(top_venues: list[str], student_domain: str) -> tuple[bool, str]:
    """
    Check if researcher's top publication venues match student domain.
    A student in ML seeing a supervisor whose top venue is 'PMLA' = instant reject.
    """
    humanities_venues = {k for k, v in VENUE_DISCIPLINE_MAP.items() 
                         if v in ("literary_studies", "classics", "medieval_studies")}
    
    if any(venue in humanities_venues for venue in top_venues):
        return False, f"venue_mismatch:humanities_venue_detected"
    
    return True, "venue_ok"

async def two_layer_domain_check(
    candidate: dict,
    student_domain: str,
    llm_chain  # domain_check_chain (LangChain)
) -> dict:
    """
    Layer 1: Fast blacklist + venue check (free, instant)
    Layer 2: LLM deep semantic check (only if Layer 1 passes)
    """
    title = candidate.get("title", "")
    abstract = candidate.get("abstract", "")[:600]
    venues = candidate.get("top_venues", [])
    
    # Layer 1a: keyword blacklist
    passes_blacklist, reason = layer1_blacklist_check(title, abstract, student_domain)
    if not passes_blacklist:
        return {"relevant": False, "method": "blacklist", "reason": reason, "llm_used": False}
    
    # Layer 1b: venue check
    passes_venue, reason = layer1_venue_check(venues, student_domain)
    if not passes_venue:
        return {"relevant": False, "method": "venue_check", "reason": reason, "llm_used": False}
    
    # Layer 2: LLM deep check (only reaches here if Layer 1 passes)
    result = await llm_chain.ainvoke({
        "student_areas": student_domain,
        "title": title,
        "abstract": abstract
    })
    return {**result.dict(), "method": "llm_deep_check", "llm_used": True}

# Expected savings: ~40% of candidates blocked by Layer 1 → 40% fewer LLM calls
```

